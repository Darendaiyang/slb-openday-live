rules_version = '2';
// 活动日临时规则：允许写入签到与计数。公开站点可能被刷量，活动结束后请删除项目或收紧规则。
service cloud.firestore {
  match /databases/{database}/documents {
    match /meta/{document=**} {
      allow read, write: if true;
    }
    match /checkins/{document=**} {
      allow read, write: if true;
    }
  }
}
